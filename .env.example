# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=wine-labels

# v1 auth posture (single-user / open mode)
OWNER_USER_ID=11111111-1111-1111-1111-111111111111
REQUIRE_AUTH=false

# AI provider keys (optional in Phase 0; stubs are used until real features call AI)
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# AI gateway
AI_LABEL_PROVIDER=gemini
AI_LABEL_MODEL=gemini-2.5-flash
AI_REC_PROVIDER=gemini
AI_REC_MODEL=gemini-2.5-flash
AI_PREF_PROVIDER=gemini
AI_PREF_MODEL=gemini-2.5-flash
